# =============================================================================
# Beispiel für Umgebungsvariablen. Kopiere diese Datei nach .env und trage
# die echten Werte ein. .env wird nicht ins Repository übernommen.
# =============================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# OpenAI (KI-Funktionen: SEO-Generierung, Story-Metadaten, HTML-Optimierung, Cookie-Klassifikation)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""
# Optional: Modell für Chat Completions (z. B. gpt-4o-mini, gpt-4o). Ohne Angabe: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Stripe, PayPal, SMTP, APP_BASE_URL etc. je nach Bedarf ergänzen.
